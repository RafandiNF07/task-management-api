generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 1. ENUMS (State Machine & RBAC)
// ==========================================
enum ProjectRole {
  LEADER
  ASSISTANT
  QUALITY_CHECK
  MEMBER
}

enum TaskStatus {
  TODO          // Menunggu Pekerja
  IN_PROGRESS   // Sedang Dikerjakan
  IN_REVIEW     // Direview
  REVISION      // Ditolak (Kembali dikerjakan/Revisi)
  DONE          // Diterima & Selesai
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ==========================================
// 2. MODELS
// ==========================================

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?

  // Relasi Kebalikan (Reverse Relations)
  projects   ProjectMember[]
  tasks      Task[]          @relation("TaskAssignee")
  comments   Comment[]
  activities ActivityLog[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Project {
  id          Int      @id @default(autoincrement())
  name        String
  description String?

  // Arsitektur Soft Delete
  isArchived  Boolean   @default(false)
  deletedAt   DateTime?

  // Relasi
  members     ProjectMember[]
  tasks       Task[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Tabel Perantara (Junction Table) untuk Multitenant RBAC
model ProjectMember {
  id        Int         @id @default(autoincrement())
  role      ProjectRole @default(MEMBER)

  // Relasi ke User dan Project
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId Int

  joinedAt  DateTime    @default(now())

  // Mencegah 1 user masuk ke project yang sama 2 kali
  @@unique([projectId, userId])
}

model Task {
  id          Int          @id @default(autoincrement())
  title       String
  description String?      @db.Text
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(NORMAL)
  deadline    DateTime?

  // Arsitektur Soft Delete
  isArchived  Boolean      @default(false)
  deletedAt   DateTime?

  // Relasi ke Project
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   Int

  // Relasi ke User (Assignee/Pekerja) - Opsional karena awalnya "Menunggu Pekerja"
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  assigneeId  Int?

  // Sub-relasi
  comments    Comment[]
  activities  ActivityLog[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text

  // Relasi
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    Int
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  action    String   // Contoh: "STATUS_CHANGED", "TASK_ASSIGNED"
  oldValue  String?  // Menyimpan state lama (misal: "IN_REVIEW")
  newValue  String?  // Menyimpan state baru (misal: "REVISION")

  // Relasi
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    Int
  actor     User     @relation(fields: [actorId], references: [id], onDelete: Cascade)
  actorId   Int

  createdAt DateTime @default(now())
}